# Comparative genomics workflow - local environment (DO NOT commit real paths/names)
# 比较基因组流程 - 本机环境（勿提交真实路径/种名）
#
#   cp .project_env.example .project_env
#   edit / 编辑后: source .project_env

export PROJECT_ROOT="/path/to/project_root"

export RESULTS_DIR="${PROJECT_ROOT}/old_reults/results"
export SCRIPTS_DIR="${PROJECT_ROOT}/annotation/scripts"
export ANNOTATION_DIR="${PROJECT_ROOT}/old_reults/annotation"
export COMPARATIVE_DIR="${PROJECT_ROOT}/comparative_genomics"
export CG_SCRIPTS_DIR="${COMPARATIVE_DIR}/scripts"
export LOGS_DIR="${COMPARATIVE_DIR}/logs"
export TOOLS_DIR="${PROJECT_ROOT}/old_reults/tools"
export RNA_DIR="${PROJECT_ROOT}/old_reults/rna_rawdata"
export CONFIG_DIR="${PROJECT_ROOT}/config"
export SPECIES_CSV="${CONFIG_DIR}/species.csv"

# Target genomes (neutral layout)
export T01_GENOME="${RESULTS_DIR}/targets/T01/T01.Chr.final.fa"
export T02_GENOME="${RESULTS_DIR}/targets/T02/T02.Chr.final.fa"

# Runtime
export THREADS=32
export CONDA_ENV=comparative
# export ORTHOFINDER=orthofinder
# export ORTHOFINDER_PY=/path/to/orthofinder.py

# Legacy aliases used by some archived scripts
export WF_PROJECT_ROOT="${PROJECT_ROOT}"
export WF_RESULTS_DIR="${RESULTS_DIR}"
export WF_SCRIPTS_DIR="${SCRIPTS_DIR}"
export WF_ANNOTATION_DIR="${ANNOTATION_DIR}"
export WF_COMPARATIVE_DIR="${COMPARATIVE_DIR}"
export WF_LOGS_DIR="${LOGS_DIR}"
export WF_TOOLS_DIR="${TOOLS_DIR}"
export WF_RNA_DIR="${RNA_DIR}"
export WF_T01_GENOME="${T01_GENOME}"
export WF_T02_GENOME="${T02_GENOME}"
